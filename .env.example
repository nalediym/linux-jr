# Linux Jr — environment variables
#
# Copy this file to `.env` or `.env.local` and fill in real values.
# `.env` files are gitignored.
#
# All client-side vars must be prefixed VITE_ — Vite exposes those to
# the browser. Unprefixed vars stay server-side (for scripts/).

# ─── Observability (Phase 1 — optional) ──────────────────────────
# Sentry DSN for error tracking in prod. Leave empty to disable.
# Get from https://sentry.io → project settings → Client Keys (DSN)
# When set, src/sentry.js auto-initializes. When empty, no-op.
VITE_SENTRY_DSN=

# Vercel Analytics is configured via the Vercel dashboard, not env vars.
# See docs/setup/vercel-analytics.md


# ─── Voice generation (Phase 2 bible content — script-only) ──────
# ElevenLabs API key for scripts/generate-voice.js.
# Only needed when regenerating mission narration MP3s.
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional — your cloned voice ID. Defaults to "Rachel" preset.
ELEVENLABS_VOICE_ID=
