# .envrc — direnv config for linux-jr
# Install: https://direnv.net/
# Activate: cd into the repo once, then run `direnv allow`
#
# Prints a banner when you cd into the repo. ADHD-safe reminder that
# this is PUBLIC.

export LINUX_JR_PUBLIC="yes"

# Print banner (once per cd-in). direnv runs this on directory entry.
printf "\033[1;36m🌍 linux-jr — PUBLIC REPO\033[0m  \033[2m(see PROTOCOLS.md)\033[0m\n"

# If it's late night / early morning, extra warning
HOUR=$(date +%H)
if [ "$HOUR" -lt 7 ] || [ "$HOUR" -ge 22 ]; then
  printf "\033[1;33m⏰ It's %s:00 — outside 7 AM–10 PM window.\033[0m\n" "$HOUR"
fi
