{
  "name": "linux-jr",
  "version": 1,
  "sources": {
    "include": [
      "../linux-jr-story/**/*.md",
      "../linux-jr-story/**/*.yaml",
      "src/data/missions/**/*.js",
      "CLAUDE.md"
    ],
    "exclude": ["node_modules/**", "dist/**", ".git/**", "kb/**"]
  },
  "compile": {
    "concept_threshold": 2,
    "max_context_tokens": 200000,
    "incremental": true,
    "batch_size": 10
  },
  "provenance": {
    "required": true,
    "method": "chunk",
    "chunk_strategy": "heading"
  },
  "obsidian": false,
  "output_dir": "kb/output"
}
