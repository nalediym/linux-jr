{
  "name": "linux-jr",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "author": "Naledi (@nalediym)",
  "description": "A browser-based Linux terminal for kids (age 7+). Teaches real Linux commands through missions, not lessons.",
  "homepage": "https://linux-jr.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/nalediym/linux-jr.git"
  },
  "type": "module",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "guard": "bash scripts/sloppy-guard.sh",
    "preview": "vite preview",
    "knip": "knip",
    "size": "size-limit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun",
    "prose": "alex README.md docs/**/*.md",
    "changeset": "changeset",
    "release": "changeset version",
    "postinstall": "lefthook install 2>/dev/null || true",
    "cli:build": "bun run --filter linuxjr build",
    "cli:test": "bun run --filter linuxjr test",
    "cli:dev": "bun run --filter linuxjr dev"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@fontsource-variable/fredoka": "^5.2.10",
    "@xterm/xterm": "^5.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "alex": "^11.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "knip": "^6.6.0",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "size-limit": "^12.1.0",
    "vite": "^8.0.1"
  }
}
